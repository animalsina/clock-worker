+            ),
+            [
+                (
+                    "Scegli durata pausa",
+                    lambda: self._request_regular_pause_duration("stop"),
+                )
+            ],
+        )
+        if not restoring:
+            self._play_timer_end_sound()
+        self._save_runtime_state(force=True)
