{
  "merge_mode": "merge",
  "project_name": "workbreak-guard",
  "source_path": ".",
  "output_name": "{project_name}-export",
  "destination_path": "~/Vibing/{project_name}/exports",
  "include_extensions": [],
  "exclude_extensions": [
    ".zip",
    ".log"
  ],
  "include_paths": [],
  "exclude_paths": [
    ".git",
    "node_modules",
    "vendor",
    "dist",
    "build",
    "docker/mysql/data",
    "docker/mariadb/data",
    "docker/postgres/data",
    "docker/postgresql/data",
    "docker/redis/data",
    "mysql/data",
    "mariadb/data",
    "postgres/data",
    "postgresql/data",
    "redis/data"
  ],
  "required_paths": [],
  "max_file_size_bytes": 52428800,
  "include_version_in_name": true,
  "version_file": "version.json",
  "version_json_path": "version",
  "version_prefix": "v",
  "generate_agent_instructions": true,
  "agent_instructions_filename": "AGENT-MAKEZIP.md",
  "return_zip_name_template": "{project_name}-delta-{version}.zip",
  "returned_zips_path": "~/Scaricati/{project_name}-returned-zips",
  "returned_zip_name": "",
  "returned_zip_prefix": "",
  "returned_zip_suffix": "-delta-{version}.zip",
  "returned_zip_glob": "*.zip",
  "delete_returned_zips_after_apply": true,
  "apply_keep_restore": true,
  "apply_restore_path": "~/Vibing/{project_name}/.makezip_restore",
  "apply_last_returned_zip_path": ".makezip_restore/last-applied-returned.zip",
  "apply_fail_on_sensitive": false,
  "use_ignore_files": true,
  "ignore_files": [
    ".gitignore"
  ],
  "use_cache": true,
  "cache_path": "~/.cache/makezip/{project_name}",
  "profile": false,
  "show_cleanup_suggestions": false,
  "use_focused_terminal_for_shortcuts": true,
  "focused_terminal_max_age_seconds": 30,
  "register_project_on_use": true,
  "show_returned_zips_in_file_picker": true,
  "copy_to_clipboard": true,
  "clipboard_mode": "file",
  "clipboard_package_name_mode": "return",
  "clipboard_include_filename": true,
  "add_timestamp": true,
  "compression_level": 1,
  "fail_on_sensitive": false,
  "warn_sensitive": true,
  "include_hidden": true,
  "output_prefix": "",
  "output_suffix": ""
}
